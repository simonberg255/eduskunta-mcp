# JWT secret — must be at least 32 characters
MCP_SERVER_JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-chars

# Public base URL of this server as seen by Intric (e.g. your ngrok HTTPS URL).
# Intric uses this to fetch the logo. No trailing slash.
SERVER_BASE_URL=https://your-ngrok-url.ngrok-free.app

# Optional: lock JWT tokens to this server
MCP_SERVER_JWT_ISSUER=
MCP_SERVER_JWT_AUDIENCE=
